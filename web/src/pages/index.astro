---
export const prerender = true;

import { Image } from 'astro:assets';
import SiteLayout from '../layouts/SiteLayout.astro';
import { site } from '../data/site';
import {
	waitlistFieldAttributes,
	waitlistStatusMessages,
} from '../lib/waitlist';
---
<SiteLayout title={`${site.name} | Home`} description={site.description}>
	<!-- Section 1: Hero -->
	<section class="section section--macros">
		<div class="container container--hero">
			<div class="macros-hero-copy">
				<h1 class="huge-title">MACROS</h1>
				<div class="down-arrow">
					<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="12" y1="5" x2="12" y2="19"></line><polyline points="19 12 12 19 5 12"></polyline></svg>
				</div>
				<div class="subtitle">Simplest Calorie - Macro tracker</div>
			</div>
			<div class="macros-hero-visual">
				<Image
					class="hero-device-img"
					src={site.heroShowcase[0].src}
					alt={site.heroShowcase[0].alt}
					format="webp"
					widths={[360, 720]}
					sizes="(max-width: 960px) 44vw, 22vw"
				/>
			</div>
		</div>
	</section>

	<!-- Section 3: App Photos Carousel -->
	<section class="section section--carousel">
		<div class="container">
			<h2 class="carousel-title">APP Photos</h2>
			<div class="carousel-container">
				<button
					type="button"
					class="carousel-nav carousel-nav--prev"
					aria-label="Previous"
					aria-controls="app-photos-carousel"
					data-carousel-prev
				>
					<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="15 18 9 12 15 6"></polyline></svg>
				</button>

				<div id="app-photos-carousel" class="carousel-track" data-carousel-track>
					{
						site.screenshots.map((screenshot) => (
							<article class="carousel-card">
								<div class="carousel-card__media">
									<Image
										src={screenshot.src}
										alt={screenshot.alt}
										loading="lazy"
										format="webp"
										widths={[320, 640]}
										sizes="(max-width: 960px) 50vw, 25vw"
									/>
								</div>
								<div class="carousel-card__title">
									{screenshot.title}
								</div>
							</article>
						))
					}
				</div>

				<button
					type="button"
					class="carousel-nav carousel-nav--next"
					aria-label="Next"
					aria-controls="app-photos-carousel"
					data-carousel-next
				>
					<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="9 18 15 12 9 6"></polyline></svg>
				</button>
			</div>
		</div>
	</section>

	<!-- Section 4: Waitlist -->
	<section class="section section--waitlist">
		<div class="container container--waitlist">
			<div class="waitlist-visual">
				<Image
					class="hero-device-img waitlist-device-img"
					src={site.screenshots[2].src}
					alt="Logged meals UI"
					loading="lazy"
					format="webp"
					widths={[360, 720]}
					sizes="(max-width: 960px) 44vw, 22vw"
				/>
			</div>

			<div class="waitlist-form-container">
				<h2>Join waitlist</h2>
				<p
					class="status waitlist-status"
					data-waitlist-status
					data-default-message={waitlistStatusMessages.submitted}
					data-default-error-message={waitlistStatusMessages.error}
				>
					{waitlistStatusMessages.submitted}
				</p>
				<form
					class="waitlist-form"
					action="/api/waitlist"
					method="POST"
					data-waitlist-form
				>
					<input
						type="email"
						name="email"
						placeholder="Email address"
						required
						maxlength={waitlistFieldAttributes.email.maxLength}
						class="waitlist-input"
					/>
					<button type="submit" class="waitlist-submit" aria-label="Join Waitlist">
						<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"></line><polyline points="12 5 19 12 12 19"></polyline></svg>
					</button>
				</form>
			</div>
		</div>
	</section>

	<script>
		import {
			getWaitlistEmailValidationMessage,
			normalizeWaitlistEmail,
		} from '../lib/waitlist-validation';

		type WaitlistFormResponse = {
			message?: string;
			fieldErrors?: Record<string, unknown>;
		} | null;

		const carouselTrack = document.querySelector('[data-carousel-track]');
		const previousCarouselButton = document.querySelector('[data-carousel-prev]');
		const nextCarouselButton = document.querySelector('[data-carousel-next]');
		const form = document.querySelector('[data-waitlist-form]');
		const status = document.querySelector('[data-waitlist-status]');
		const defaultSuccessMessage =
			status instanceof HTMLElement ? status.dataset.defaultMessage ?? status.textContent ?? '' : '';
		const defaultErrorMessage =
			status instanceof HTMLElement ? status.dataset.defaultErrorMessage ?? '' : '';
		let waitlistStatusTimeout: number | null = null;

		function hideStatusElement(element: Element | null) {
			if (!(element instanceof HTMLElement)) {
				return;
			}

			element.classList.remove('waitlist-status--visible');
		}

		function showStatusElement(element: Element | null, message: string, tone: 'success' | 'error') {
			if (!(element instanceof HTMLElement)) {
				return;
			}

			if (waitlistStatusTimeout !== null) {
				window.clearTimeout(waitlistStatusTimeout);
				waitlistStatusTimeout = null;
			}

			element.textContent = message;
			element.classList.remove('status--success', 'status--error');
			element.classList.add(tone === 'success' ? 'status--success' : 'status--error');
			element.classList.remove('waitlist-status--visible');
			void element.offsetWidth;
			element.classList.add('waitlist-status--visible');

			waitlistStatusTimeout = window.setTimeout(() => {
				hideStatusElement(element);
				waitlistStatusTimeout = null;
			}, 5000);
		}

		function showStatusSuccess(message = defaultSuccessMessage) {
			if (!(status instanceof HTMLElement)) {
				return;
			}

			showStatusElement(status, message, 'success');
		}

		function showStatusError(message = defaultErrorMessage) {
			if (!(status instanceof HTMLElement)) {
				return;
			}

			showStatusElement(status, message, 'error');
		}

		function clearStatus() {
			if (!(status instanceof HTMLElement)) {
				return;
			}

			status.textContent = defaultSuccessMessage;
			status.classList.remove('status--success', 'status--error');
			hideStatusElement(status);
		}

		function getEmailControl() {
			if (!(form instanceof HTMLFormElement)) {
				return null;
			}

			const control = form.elements.namedItem('email');

			return control instanceof HTMLInputElement ? control : null;
		}

		function getSubmitControl() {
			if (!(form instanceof HTMLFormElement)) {
				return null;
			}

			const control = form.querySelector('.waitlist-submit');

			return control instanceof HTMLButtonElement ? control : null;
		}

		function getNormalizedWaitlistEmailValue() {
			const emailControl = getEmailControl();

			return normalizeWaitlistEmail(emailControl?.value ?? '');
		}

		function setWaitlistSubmitEnabled(isEnabled: boolean) {
			const submitControl = getSubmitControl();

			if (!submitControl) {
				return;
			}

			submitControl.disabled = !isEnabled;
			submitControl.setAttribute('aria-disabled', String(!isEnabled));
		}

		function syncWaitlistEmailValidity() {
			const emailControl = getEmailControl();

			if (!emailControl) {
				return false;
			}

			const normalizedValue = getNormalizedWaitlistEmailValue();
			const message =
				normalizedValue.length === 0
					? ''
					: getWaitlistEmailValidationMessage(normalizedValue) ?? '';
			const isValid = normalizedValue.length > 0 && message.length === 0;

			emailControl.setCustomValidity(message);

			return isValid;
		}

		function syncWaitlistSubmitState() {
			const emailControl = getEmailControl();

			if (!emailControl) {
				return false;
			}

			const normalizedValue = getNormalizedWaitlistEmailValue();

			if (normalizedValue.length === 0) {
				emailControl.setCustomValidity('');
				setWaitlistSubmitEnabled(false);
				return false;
			}

			const isValid = syncWaitlistEmailValidity();
			setWaitlistSubmitEnabled(isValid);
			return isValid;
		}

		async function parseWaitlistResponse(response: Response): Promise<WaitlistFormResponse> {
			const result = await response.json().catch(() => null);

			if (!result || typeof result !== 'object') {
				return null;
			}

			return result as WaitlistFormResponse;
		}

		function carouselScrollAmount() {
			if (!(carouselTrack instanceof HTMLElement)) {
				return 0;
			}

			const cards = carouselTrack.querySelectorAll('.carousel-card');
			const firstCard = cards.item(0);
			const secondCard = cards.item(1);

			if (!(firstCard instanceof HTMLElement)) {
				return 0;
			}

			if (secondCard instanceof HTMLElement) {
				return secondCard.offsetLeft - firstCard.offsetLeft;
			}

			return firstCard.offsetWidth;
		}

		function scrollCarousel(direction: 1 | -1) {
			if (!(carouselTrack instanceof HTMLElement)) {
				return;
			}

			const amount = carouselScrollAmount();

			if (amount <= 0) {
				return;
			}

			carouselTrack.scrollBy({
				left: amount * direction,
				behavior: 'smooth',
			});
		}

		if (previousCarouselButton instanceof HTMLButtonElement) {
			previousCarouselButton.addEventListener('click', () => {
				scrollCarousel(-1);
			});
		}

		if (nextCarouselButton instanceof HTMLButtonElement) {
			nextCarouselButton.addEventListener('click', () => {
				scrollCarousel(1);
			});
		}

		if (form instanceof HTMLFormElement) {
			syncWaitlistSubmitState();

			form.addEventListener('input', () => {
				syncWaitlistSubmitState();
			});

			form.addEventListener('submit', async (event) => {
				event.preventDefault();

				const emailControl = getEmailControl();
				clearStatus();

				const isReadyToSubmit = syncWaitlistSubmitState();

				if (!isReadyToSubmit) {
					if (emailControl?.validationMessage) {
						emailControl.reportValidity();
					} else {
						showStatusError(defaultErrorMessage);
					}
					return;
				}

				if (!form.reportValidity()) {
					return;
				}

				try {
					const response = await fetch('/api/waitlist', {
						method: 'POST',
						headers: {
							'content-type': 'application/json',
							accept: 'application/json',
						},
						body: JSON.stringify({
							email: emailControl?.value ?? '',
						}),
					});
					const result = await parseWaitlistResponse(response);

					if (response.ok) {
						form.reset();
						emailControl?.setCustomValidity('');
						syncWaitlistSubmitState();
						showStatusSuccess(
							typeof result?.message === 'string' ? result.message : defaultSuccessMessage,
						);
						return;
					}

					const fieldError =
						result?.fieldErrors && typeof result.fieldErrors.email === 'string'
							? result.fieldErrors.email
							: null;
					const message =
						typeof result?.message === 'string' ? result.message : defaultErrorMessage;

					if (emailControl && fieldError) {
						emailControl.setCustomValidity(fieldError);
						setWaitlistSubmitEnabled(false);
						emailControl.reportValidity();
					}

					showStatusError(message);
				} catch {
					showStatusError(defaultErrorMessage);
				}
			});
		}
	</script>
</SiteLayout>

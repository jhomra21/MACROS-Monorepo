---
export const prerender = true;

import { site } from '../data/site';
import SiteLayout from '../layouts/SiteLayout.astro';
import {
	supportFieldAttributes,
	supportStatusElementIDs,
	supportStatusMessages,
} from '../lib/support';
---

<SiteLayout title={`${site.name} | Support`} description="Get support for Cal Macro Tracker.">
	<section class="page-header">
		<div class="container">
			<span class="eyebrow">Support</span>
			<h1>Need help with the app?</h1>
			<p>
				Send a support request with your name, email, and a short description of the
				problem. The request is stored so it can be reviewed and answered.
			</p>
		</div>
	</section>

	<section class="section">
		<div class="container support-layout">
			<aside class="support-card">
				<h2>What to include</h2>
				<ul class="support-list">
					{site.supportChecklist.map((item) => <li>{item}</li>)}
				</ul>
			</aside>

			<div class="support-card">
				<h2>Contact support</h2>
				<p
					id={supportStatusElementIDs.submitted}
					class="status status--success support-status-banner"
					data-support-success
					data-default-message={supportStatusMessages.submitted}
				>
					{supportStatusMessages.submitted}
				</p>
				<p
					id={supportStatusElementIDs.invalid}
					class="status status--error support-status-banner"
					data-support-invalid
					data-default-message={supportStatusMessages.invalid}
				>
					{supportStatusMessages.invalid}
				</p>
				<p
					id={supportStatusElementIDs.error}
					class="status status--error support-status-banner"
					data-support-error
					data-default-message={supportStatusMessages.error}
				>
					{supportStatusMessages.error}
				</p>

				<form class="field-list" method="POST" action="/api/support" data-support-form>
					<div class="field">
						<label for="name">Name</label>
						<input
							id="name"
							name="name"
							type="text"
							autocomplete="name"
							minlength={supportFieldAttributes.name.minLength}
							maxlength={supportFieldAttributes.name.maxLength}
							required
						/>
					</div>

					<div class="field">
						<label for="email">Email</label>
						<input
							id="email"
							name="email"
							type="email"
							autocomplete="email"
							maxlength={supportFieldAttributes.email.maxLength}
							required
						/>
					</div>

					<div class="field">
						<label for="message">Describe the problem</label>
						<textarea
							id="message"
							name="message"
							minlength={supportFieldAttributes.message.minLength}
							maxlength={supportFieldAttributes.message.maxLength}
							aria-describedby="message-hint"
							required
						></textarea>
						<p class="field-hint" id="message-hint">
							Please share at least {supportFieldAttributes.message.minLength}
							characters so support has enough detail to help.
						</p>
					</div>

					<button class="button" type="submit">Send request</button>
				</form>
			</div>
		</div>
	</section>

	<script>
		type SupportFormResponse = {
			message?: string;
			fieldErrors?: Record<string, unknown>;
		} | null;

		const form = document.querySelector('[data-support-form]');
		const success = document.querySelector('[data-support-success]');
		const invalid = document.querySelector('[data-support-invalid]');
		const error = document.querySelector('[data-support-error]');
		const defaultSuccessMessage =
			success instanceof HTMLElement ? success.dataset.defaultMessage ?? success.textContent ?? '' : '';
		const defaultInvalidMessage =
			invalid instanceof HTMLElement ? invalid.dataset.defaultMessage ?? invalid.textContent ?? '' : '';
		const defaultErrorMessage =
			error instanceof HTMLElement ? error.dataset.defaultMessage ?? error.textContent ?? '' : '';
		const statusElements = {
			submitted: success,
			invalid,
			error,
		} as const;

		function setVisibleStatus(nextStatus: keyof typeof statusElements | null) {
			for (const [status, element] of Object.entries(statusElements)) {
				if (!(element instanceof HTMLElement)) {
					continue;
				}

				element.classList.toggle('is-visible', status === nextStatus);
			}
		}

		function showStatusSubmitted(message = defaultSuccessMessage) {
			if (!(success instanceof HTMLElement)) {
				return;
			}

			success.textContent = message;
			setVisibleStatus('submitted');
		}

		function showStatusInvalid(message = defaultInvalidMessage) {
			if (!(invalid instanceof HTMLElement)) {
				return;
			}

			invalid.textContent = message;
			setVisibleStatus('invalid');
		}

		function showStatusError(message = defaultErrorMessage) {
			if (!(error instanceof HTMLElement)) {
				return;
			}

			error.textContent = message;
			setVisibleStatus('error');
		}

		function clearStatus() {
			if (success instanceof HTMLElement) {
				success.textContent = defaultSuccessMessage;
			}

			if (invalid instanceof HTMLElement) {
				invalid.textContent = defaultInvalidMessage;
			}

			if (error instanceof HTMLElement) {
				error.textContent = defaultErrorMessage;
			}

			setVisibleStatus(null);
		}

		const supportPageHash = window.location.hash;

		if (success instanceof HTMLElement && supportPageHash === `#${success.id}`) {
			showStatusSubmitted();
			window.history.replaceState({}, '', window.location.pathname);
		} else if (invalid instanceof HTMLElement && supportPageHash === `#${invalid.id}`) {
			showStatusInvalid();
			window.history.replaceState({}, '', window.location.pathname);
		} else if (error instanceof HTMLElement && supportPageHash === `#${error.id}`) {
			showStatusError();
			window.history.replaceState({}, '', window.location.pathname);
		}

		function getFormControl(fieldName: string) {
			if (!(form instanceof HTMLFormElement)) {
				return null;
			}

			const control = form.elements.namedItem(fieldName);

			if (control instanceof HTMLInputElement || control instanceof HTMLTextAreaElement) {
				return control;
			}

			return null;
		}

		function clearFieldValidation() {
			if (!(form instanceof HTMLFormElement)) {
				return;
			}

			for (const element of Array.from(form.elements)) {
				if (element instanceof HTMLInputElement || element instanceof HTMLTextAreaElement) {
					element.setCustomValidity('');
				}
			}
		}

		function applyFieldErrors(fieldErrors: Record<string, unknown> | undefined) {
			if (!fieldErrors || typeof fieldErrors !== 'object') {
				return false;
			}

			let hasFieldErrors = false;
			let firstInvalidControl = null;

			for (const [fieldName, message] of Object.entries(fieldErrors)) {
				if (typeof message !== 'string' || message.length === 0) {
					continue;
				}

				const control = getFormControl(fieldName);

				if (!control) {
					continue;
				}

				control.setCustomValidity(message);
				hasFieldErrors = true;
				firstInvalidControl ??= control;
			}

			firstInvalidControl?.reportValidity();

			return hasFieldErrors;
		}

		async function parseSupportResponse(response: Response): Promise<SupportFormResponse> {
			const result = await response.json().catch(() => null);

			if (!result || typeof result !== 'object') {
				return null;
			}

			return result as SupportFormResponse;
		}

		if (form instanceof HTMLFormElement) {
			form.addEventListener('input', (event) => {
				const target = event.target;

				if (target instanceof HTMLInputElement || target instanceof HTMLTextAreaElement) {
					target.setCustomValidity('');
				}
			});

			form.addEventListener('submit', async (event) => {
				event.preventDefault();

				clearFieldValidation();
				clearStatus();

				if (!form.reportValidity()) {
					return;
				}

				const formData = new FormData(form);
				const payload = Object.fromEntries(formData.entries());

				try {
					const response = await fetch('/api/support', {
						method: 'POST',
						headers: {
							'content-type': 'application/json',
							accept: 'application/json',
						},
						body: JSON.stringify(payload),
					});
					const result = await parseSupportResponse(response);

					if (response.ok) {
						form.reset();
						showStatusSubmitted(
							typeof result?.message === 'string' ? result.message : defaultSuccessMessage,
						);
						return;
					}

					const isValidationFailure = response.status >= 400 && response.status < 500;
					const message = typeof result?.message === 'string'
						? result.message
						: isValidationFailure
							? defaultInvalidMessage
							: defaultErrorMessage;
					const hasFieldErrors = applyFieldErrors(result?.fieldErrors);

					if (isValidationFailure) {
						showStatusInvalid(message);
					} else {
						showStatusError(message);
					}

					if (!hasFieldErrors) {
						form.reportValidity();
					}
				} catch {
					showStatusError(defaultErrorMessage);
				}
			});
		}
	</script>
</SiteLayout>

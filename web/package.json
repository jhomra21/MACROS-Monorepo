{
  "name": "cal-macro-tracker-web",
  "private": true,
  "packageManager": "bun@1.3.11",
  "type": "module",
  "version": "0.0.1",
  "engines": {
    "node": ">=22.12.0"
  },
  "scripts": {
    "dev": "set -m; bun run dev:api & api_pid=$!; trap 'kill -- -$api_pid' EXIT INT TERM; bun run dev:astro",
    "dev:astro": "astro dev",
    "dev:api": "wrangler types --config wrangler.api.jsonc && wrangler dev --config wrangler.api.jsonc",
    "dev:worker": "bun run build && wrangler dev",
    "build": "wrangler types && astro check && tsc --noEmit && astro build",
    "preview": "bun run dev:worker",
    "deploy": "bun run build && bun run db:migrations:apply:remote && wrangler deploy",
    "deploy:dry-run": "bun run build && wrangler deploy --dry-run",
    "check": "wrangler types && astro check && tsc --noEmit",
    "types": "wrangler types",
    "db:migrations:apply:local": "wrangler d1 migrations apply SUPPORT_DB --local",
    "db:migrations:apply:remote": "wrangler d1 migrations apply SUPPORT_DB --remote",
    "astro": "astro"
  },
  "dependencies": {
    "astro": "^6.1.6",
    "zod": "^4.1.12"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.8",
    "@types/node": "^25.6.0",
    "typescript": "^5.9.3",
    "wrangler": "^4.82.2"
  }
}
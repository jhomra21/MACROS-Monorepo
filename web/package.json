{
  "name": "cal-macro-tracker-web",
  "private": true,
  "packageManager": "bun@1.3.11",
  "type": "module",
  "version": "0.0.1",
  "engines": {
    "node": ">=22.12.0"
  },
  "scripts": {
    "dev": "wrangler types && astro dev",
    "build": "wrangler types && astro check && astro build",
    "preview": "wrangler types && astro build && astro preview",
    "deploy": "bun run build && bun run db:migrations:apply:remote && wrangler deploy",
    "deploy:dry-run": "bun run build && wrangler deploy --dry-run",
    "check": "wrangler types && astro check",
    "types": "wrangler types",
    "db:migrations:apply:local": "wrangler d1 migrations apply SUPPORT_DB --local",
    "db:migrations:apply:remote": "wrangler d1 migrations apply SUPPORT_DB --remote",
    "astro": "astro"
  },
  "dependencies": {
    "@astrojs/cloudflare": "^13.1.9",
    "astro": "^6.1.6"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.8",
    "@types/node": "^25.6.0",
    "typescript": "^5.9.3",
    "wrangler": "^4.82.2"
  }
}